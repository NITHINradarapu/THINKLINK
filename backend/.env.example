# ThinkLink Configuration Settings
# Copy this file to .env and fill in your values

APP_NAME=ThinkLink
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
HOST=localhost
PORT=8000

# lowercase aliases (required by pydantic-settings)
app_name=ThinkLink
app_version=1.0.0
environment=development
debug=true
host=localhost
port=8000

# Database
DATABASE_URL=sqlite:///./thinklink.db
database_url=sqlite:///./thinklink.db

# AI Service Settings (Ollama or compatible LLM endpoint)
AI_SERVICE_URL=http://localhost:11434/api/generate
AI_ANALYZE_ENDPOINT=/ai/analyze
AI_HEALTH_ENDPOINT=/health
AI_TIMEOUT=30

ai_service_url=http://localhost:11434/api/generate
ai_analyze_endpoint=/ai/analyze
ai_health_endpoint=/health
ai_timeout=30
ai_cooldown_seconds=60

# Upload Limits
UPLOAD_DIRECTORY=./uploads
MAX_IMAGE_SIZE_MB=10
MAX_AUDIO_SIZE_MB=10

upload_directory=./uploads
max_image_size_mb=10
max_audio_size_mb=10

# Thresholds
TEMP_THRESHOLD=80.0
GAS_THRESHOLD=300.0
HUMIDITY_THRESHOLD=80.0
BATTERY_THRESHOLD=15

temp_threshold=80
gas_threshold=300
smoke_threshold=1
humidity_threshold=80
battery_threshold=15

# Polling and Security
poll_interval=10
secret_key=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY

# Logger
LOG_LEVEL=INFO
log_level=INFO
